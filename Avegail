    header {
      height: 100vh;
      background: linear-gradient(to bottom, #f8c8dc, #ffffff);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
    }

    header h1 {
      font-family: 'Great Vibes', cursive;
      font-size: 3rem;
      color: #d4af37;
    }

    header p {
