      text-align: center;
    }

    h2 {
      font-family: 'Great Vibes', cursive;
      color: #d4af37;
      font-size: 2.5rem;
    }

    .card {
      background: white;
      margin: 20px auto;
      padding: 20px;
      border-radius: 15px;
      max-width: 500px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .gallery img {
      width: 150px;
      margin: 10px;
      border-radius: 10px;
    }

    form input, form button {
      width: 80%;
      padding: 10px;
      margin: 10px 0;
      border-radius: 10px;
      border: 1px solid #ccc;
    }

    form button {
      background: #d4af37;
      color: white;
      border: none;
